  "periscope.rgQueryParams": [
    {
      // filter the results to a folder
      // Query: "redis -m module1"
      // After: "rg 'redis' -g '**/*module1*/**'"
      "regex": "^(.+) -m ([\\w-_]+)$",
      "param": "-g '**/*$1*/**' -g '!**/node_modules/**'",
    },
    {
      // filter the results to a folder and filetype
      // Query: "redis -m module1 yaml"
      // After: "rg 'redis' -g '**/*module1*/**/*.yaml'"
      "regex": "^(.+) -m ([\\w-_]+) ([\\w]+)$",
      "param": "-g '**/*$1*/**/*.$2'",
    },
    {
      // filter the results that match a glob
      // Query: "redis -g *module"
      // After: "rg 'redis' -g '*module'"
      "regex": "^(.+) -g (.+)$",
      "param": "-g '$1'",
    },
    {
      // filter the results to rg filetypes
      // Query: "redis -t yaml"
      // After: "rg 'redis' -t yaml"
      "regex": "^(.+) -t ?(\\w+)$",
      "param": "-t $2",
    },
    {
      // filter the results to Godot script files (.gd) when query is just "*.gd"
      // Query: "*.gd"
      // After: "rg '' -g '**/*.gd'"
      "regex": "^\\s*\\*\\.gd\\s*$",
      "param": "-g '**/*.gd'",
    },
    {
      // filter the results to Godot script files (.gd) when query is "<term> *.gd"
      // Query: "redis *.gd"
      // After: "rg 'redis' -g '**/*.gd'"
      "regex": "^(.+?)\\s+\\*\\.gd\\s*$",
      "param": "-g '**/*.gd'",
    },
    {
      // filter the results that match a file extension through a glob
      // Query: redis *.rs => rg 'redis' -g '*.rs'
      "regex": "^(.+?)\\s+\\*\\.(\\w+)\\s*$",
      "param": "-g '*.$2'",
    },
  ],
  // always exclude Godot scene files from search results unless explicitly asked for
  "periscope.rgGlobExcludes": ["**/*.tscn"],
  "extensions.experimental.affinity": {
    "vscodevim.vim": 1,
