{
  //VIM START
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 50,
  "vim.highlightedyank.color": "rgba(241, 48, 48, 1)",
  "vim.highlightedyank.textColor": "white",
  "vim.leader": "<Space>",
  "vim.easymotion": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-s>": false,
    "<C-w>": false,
    "<C-p>": false,
    "<C-b>": false,
    "<C-k>": false,
  },
  "vim.normalModeKeyBindingsNonRecursive": [
    // {
    //   "before": ["<leader>", "s", "g"],
    //   "commands": ["search.action.openEditor"],
    // },
    {
      "before": ["<leader>", "s", "g"],
      "commands": [
        {
          "command": "periscope.search",
          "when": "editorTextFocus",
        },
      ],
    },
    {
      "before": ["<leader>", "a"],
      "commands": ["vscode-harpoon.addEditor"],
    },
    {
      "before": ["<leader>", "l"],
      "commands": ["vscode-harpoon.editEditors"],
    },
    // {
    //     "before": [
    //         "<leader>",
    //         "p",
    //     ],
    //     "commands": [
    //         "vscode-harpoon.editorQuickPick"
    //     ]
    // },
    {
      "before": ["<leader>", "n"],
      "commands": ["vscode-harpoon.gotoEditor1"],
    },
    {
      "before": ["<leader>", "e"],
      "commands": ["vscode-harpoon.gotoEditor2"],
    },
    {
      "before": ["<leader>", "i"],
      "commands": ["vscode-harpoon.gotoEditor3"],
    },
    {
      "before": ["<leader>", "o"],
      "commands": ["vscode-harpoon.gotoEditor4"],
    },
    {
      "before": ["s"],
      "after": ["leader", "leader", "s"],
    },
    {
      "before": ["<leader>", "g"],
      "commands": [
        {
          "command": "periscope.search",
          "when": "editorTextFocus",
        },
      ],
    },
    {
      "before": ["<leader>", "f"],
      "commands": [
        {
          "command": "periscope.searchCurrentFile",
          "when": "editorTextFocus",
        },
      ],
    },
    {
      "before": ["Tab"],
      "commands": ["editor.action.acceptCursorTabSuggestion"],
    },
    {
      "before": ["<space>"],
      "commands": ["vspacecode.space"],
    },
    {
      "before": [","],
      "commands": [
        "vspacecode.space",
        {
          "command": "whichkey.triggerKey",
          "args": "m",
        },
      ],
    },
    {
      "before": ["leader", "/"],
      "commands": ["editor.action.commentLine"],
    },
    {
      "before": ["<Esc>"],
      "commands": [":nohl"],
    },
    {
      "before": ["K"],
      "commands": ["editor.action.showHover"],
    },
    {
      "before": ["<leader>", "<space>"],
      "commands": ["workbench.action.quickOpen"],
    },
    // {
    //   "before": ["<leader>", "<space>"],
    //   "commands": ["code-telescope.fuzzy.file"],
    // },
    // {
    //     "before": [
    //         "<leader>",
    //         "s",
    //         "g"
    //     ],
    //     "commands": [
    //         "workbench.action.findInFiles"
    //     ]
    // }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<space>"],
      "commands": ["vspacecode.space"],
    },
    {
      "before": [","],
      "commands": [
        "vspacecode.space",
        {
          "command": "whichkey.triggerKey",
          "args": "m",
        },
      ],
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"],
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"],
    },
    {
      "before": ["<leader>", "/"],
      "commands": ["editor.action.commentLine"],
      "when": "editorTextFocus && !editorReadonly",
    },
  ],
  "workbench.colorTheme": "Noir Poimandres Darker",
